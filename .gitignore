# next.js — builds happen in CI (GitHub Actions) which doesn't hit the SIGSEGV
# issue some TrueNAS hosts have, so the production image is pulled from GHCR
# rather than built per-host. Local dev still produces .next/ — we just don't
# track it.
.next/
out/

# claude code
.claude/

# local development / private notes
