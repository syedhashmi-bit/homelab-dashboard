# Truenas-Dashboard env vars
#
# Copy this file to `.env.local` (gitignored) and fill in real values for local
# development. In production, pass these via `docker run -e VAR=value` from
# /root/update-dashboard.sh on TrueNAS — never bake them into the image.
#
# Server-side only. Do NOT prefix with NEXT_PUBLIC_ — that would expose them
# to the client bundle.
#
# ─────────────────────────────────────────────────────────────────────────────
# Almost everything below has a sensible default. The only things you MUST set
# for the dashboard to do anything useful are:
#   - TRUENAS_IP            (or the per-service URLs further down)
#   - The API keys for whatever services you actually use
# Leave the rest alone unless your setup deviates from the defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ──── Core network ──────────────────────────────────────────────────────────
# Default base host that all per-service URLs derive from when their dedicated
# *_URL var isn't set. If your services live on a different host, set the
# per-service URLs below instead of this.
TRUENAS_IP=192.168.88.196

# Prometheus base URL. Defaults to http://${TRUENAS_IP}:30104.
# PROMETHEUS_URL=http://192.168.88.196:30104

# ──── Per-service URLs (override only if non-default port / different host) ──
# RADARR_URL=http://192.168.88.196:30025
# SONARR_URL=http://192.168.88.196:33027
# BAZARR_URL=http://192.168.88.196:30046
# TAUTULLI_URL=http://192.168.88.196:30047
# QBIT_URL=http://192.168.88.196:30024
# OVERSEERR_URL=http://192.168.88.196:30002
# PIHOLE_URL=http://192.168.88.196:20720
# PROWLARR_URL=http://192.168.88.196:30050
# NGINX_URL=http://192.168.88.196:30020
# UPTIME_KUMA_URL=http://192.168.88.196:31050

# ──── Router ────────────────────────────────────────────────────────────────
MIKROTIK_URL=http://192.168.88.1
MIKROTIK_USERNAME=monitor-only
MIKROTIK_PASSWORD=replace-with-real-password

# ──── *arr stack credentials ───────────────────────────────────────────────
RADARR_API_KEY=replace-with-real-key
SONARR_API_KEY=replace-with-real-key
BAZARR_API_KEY=replace-with-real-key
TAUTULLI_API_KEY=replace-with-real-key
PROWLARR_API_KEY=replace-with-real-key
OVERSEERR_API_KEY=replace-with-real-key

# ──── Torrent client ────────────────────────────────────────────────────────
# qBittorrent 5.1+ supports native API keys (Settings → WebUI → API Key,
# format `qbt_...`). Use that OR username+password — either works.
QBIT_API_KEY=
QBIT_USERNAME=admin
QBIT_PASSWORD=replace-with-real-password

# ──── DNS ───────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=replace-with-real-password

# ──── Reverse proxy (Nginx Proxy Manager) ───────────────────────────────────
NGINX_USERNAME=you@example.com
NGINX_PASSWORD=replace-with-real-password

# ──── Uptime monitoring ─────────────────────────────────────────────────────
UPTIME_KUMA_API_KEY=replace-with-real-bearer-token

# ──── Speedtest history (SpeedTracker) ──────────────────────────────────────
SPEEDTEST_API_KEY=replace-with-real-bearer-token

# ──── Filesystem labels (PromQL filters) ───────────────────────────────────
# Mountpoint prefix the dashboard considers "interesting" — only datasets under
# this path appear in the Filesystems card. Default: /mnt/Pool/Media/
# FS_PATH_PREFIX=/mnt/Pool/Media/

# Pool root path used to render the "POOL TOTAL" hero. Default: /mnt/Pool
# POOL_PATH=/mnt/Pool

# Regex of network interfaces to EXCLUDE from net throughput calculations.
# Default catches typical virtual interfaces. Override only if your host
# has unusual interface naming.
# NETWORK_DEVICE_EXCLUDE=lo|veth.*|docker.*|br.*

# ──── Weather ──────────────────────────────────────────────────────────────
# Coordinates for the weather pill in the header. Default: Launceston, TAS.
# WEATHER_LAT=-41.4419
# WEATHER_LON=147.1450

# ──── Grafana embed (optional) ─────────────────────────────────────────────
# Without GRAFANA_DASHBOARD_UID + GRAFANA_DATASOURCE_UID, the Grafana card
# renders a "not configured" state instead of a broken iframe. To enable:
#   1. Open the dashboard in Grafana
#   2. Find the dashboard UID in the URL (e.g. /d/<UID>/...)
#   3. Settings → Data sources → click your Prometheus → look at /datasources/edit/<UID>
# GRAFANA_BASE_URL=http://192.168.88.196:30037
# GRAFANA_DASHBOARD_UID=
# GRAFANA_DATASOURCE_UID=
# GRAFANA_PANEL_ID=panel-77
# GRAFANA_DASHBOARD_SLUG=node-exporter-full

# ──── Bookmarks file path (optional) ───────────────────────────────────────
# Path inside the container to a bookmarks.json file. Default reads from cwd
# (which is /app in the Docker image). Mount your file at /app/bookmarks.json
# via `-v /your/path/bookmarks.json:/app/bookmarks.json:ro` on docker run.
# BOOKMARKS_PATH=/app/bookmarks.json
