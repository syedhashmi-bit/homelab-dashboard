# Truenas-Dashboard env vars
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# In production on TrueNAS these are passed via `docker run -e VAR=value` from
# /root/update-dashboard.sh — never baked into the image.
#
# Server-side only. Do NOT prefix with NEXT_PUBLIC_ — would expose to the client bundle.

# ---- Network ----
TRUENAS_IP=192.168.88.196

# ---- *arr stack ----
RADARR_API_KEY=replace-with-real-key
SONARR_API_KEY=replace-with-real-key
BAZARR_API_KEY=replace-with-real-key
TAUTULLI_API_KEY=replace-with-real-key
PROWLARR_API_KEY=replace-with-real-key
OVERSEERR_API_KEY=replace-with-real-key

# ---- Torrent client ----
QBIT_USERNAME=admin
QBIT_PASSWORD=replace-with-real-password

# ---- DNS ----
PIHOLE_PASSWORD=replace-with-real-password

# ---- Reverse proxy (Nginx Proxy Manager) ----
NGINX_USERNAME=you@example.com
NGINX_PASSWORD=replace-with-real-password

# ---- Uptime monitoring ----
UPTIME_KUMA_API_KEY=replace-with-real-bearer-token

# ---- Router ----
MIKROTIK_USERNAME=monitor-only
MIKROTIK_PASSWORD=replace-with-real-password

# ---- Speedtest history (SpeedTracker) ----
SPEEDTEST_API_KEY=replace-with-real-bearer-token
