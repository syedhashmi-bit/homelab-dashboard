# build artifacts — the image build runs `npm run build` itself, so any
# pre-existing .next/ in the working directory is irrelevant.
.next
node_modules
npm-debug.log
tsconfig.tsbuildinfo

# version control
.git
.gitignore

# docker meta
Dockerfile
.dockerignore
docker-compose*.yml

# CI
.github

# local dev / private notes (not needed at runtime, never sensitive in repo)
*.md
.env*
.claude
Read-Prompt.txt
gh
